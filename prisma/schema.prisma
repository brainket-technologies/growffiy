generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  mobile        String?
  userId        String          @unique @map("user_id")
  password      String
  role          String          @default("client")
  status        String          @default("active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  client        Client?
  payments      Payment[]
  subscriptions Subscription[]
  tickets       SupportTicket[]

  @@map("users")
}

model Client {
  id                 String               @id @default(uuid())
  userId             String               @unique @map("user_id")
  zerodhaClientId    String?              @map("zerodha_client_id")
  accessToken        String?              @map("access_token")
  capital            Decimal              @db.Decimal(12, 2)
  strategyId         String?              @map("strategy_id")
  tradingStatus      String               @default("inactive") @map("trading_status")
  subscriptionStatus String               @default("pending") @map("subscription_status")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  zerodhaApiKey      String?              @map("zerodha_api_key")
  zerodhaApiSecret   String?              @map("zerodha_api_secret")
  zerodhaSession     String?              @map("zerodha_session")
  zerodhaPassword    String?              @map("zerodha_password")
  zerodhaTotpSecret  String?              @map("zerodha_totp_secret")
  aadhaarNumber      String?              @map("aadhaar_number")
  dob                String?              @map("dob")
  kycStatus          String               @default("pending") @map("kyc_status")
  panNumber          String?              @map("pan_number")
  productTypeId      String?              @map("product_type_id")
  productType        ProductType?         @relation(fields: [productTypeId], references: [id])
  strategy           Strategy?            @relation(fields: [strategyId], references: [id])
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments        StrategyAssignment[]
  trades             Trade[]

  @@map("clients")
}

model Strategy {
  id          String               @id @default(uuid())
  name        String
  description String?
  status      String               @default("active")
  configJson  String?              @map("config_json")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  clients     Client[]
  assignments StrategyAssignment[]
  backtests   StrategyBacktest[]
  conditions  StrategyCondition[]
  logs        StrategyLog[]
  trades      Trade[]

  @@map("strategies")
}

model Trade {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  strategyId     String    @map("strategy_id")
  symbol         String
  orderType      String    @map("order_type")
  entryPrice     Decimal?  @map("entry_price") @db.Decimal(12, 2)
  exitPrice      Decimal?  @map("exit_price") @db.Decimal(12, 2)
  quantity       Int
  stopLoss       Decimal?  @map("stop_loss") @db.Decimal(12, 2)
  target         Decimal?  @db.Decimal(12, 2)
  pnl            Decimal?  @db.Decimal(12, 2)
  status         String    @default("open")
  entryTime      DateTime? @map("entry_time")
  exitTime       DateTime? @map("exit_time")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  kiteResponse   Json?     @map("kite_response")
  entryOrderId   String?   @map("entry_order_id")
  exitReason     String?   @map("exit_reason")
  slOrderId      String?   @map("sl_order_id")
  slTriggerPrice Decimal?  @map("sl_trigger_price") @db.Decimal(12, 2)
  targetOrderId  String?   @map("target_order_id")
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  strategy       Strategy  @relation(fields: [strategyId], references: [id])

  @@map("trades")
}

model ProductType {
  id        String             @id @default(uuid())
  name      String             @unique
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  clients   Client[]
  plans     SubscriptionPlan[]

  @@map("product_types")
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  name          String
  price         Decimal        @db.Decimal(10, 2)
  durationDays  Int            @map("duration_days")
  features      String?
  status        String         @default("active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  productTypeId String?        @map("product_type_id")
  payments      Payment[]
  productType   ProductType?   @relation(fields: [productTypeId], references: [id])
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  planId    String           @map("plan_id")
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  status    String           @default("active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  planId            String           @map("plan_id")
  amount            Decimal          @db.Decimal(10, 2)
  razorpayOrderId   String           @map("razorpay_order_id")
  razorpayPaymentId String?          @map("razorpay_payment_id")
  status            String
  paymentDate       DateTime?        @map("payment_date")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model AppSettings {
  id           String   @id @default(uuid())
  settingKey   String   @unique @map("setting_key")
  settingValue String   @map("setting_value")
  type         String   @default("string")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  admin     User     @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  subject   String
  message   String
  category  String
  status    String   @default("open")
  reply     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model StrategyCondition {
  id         String   @id @default(uuid())
  strategyId String   @map("strategy_id")
  logical    String   @default("AND")
  indicator  String
  operator   String
  value      String
  createdAt  DateTime @default(now()) @map("created_at")
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("strategy_conditions")
}

model StrategyAssignment {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  strategyId String   @map("strategy_id")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("strategy_assignments")
}

model StrategyTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  configJson  String   @map("config_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("strategy_templates")
}

model StrategyLog {
  id         String   @id @default(uuid())
  strategyId String   @map("strategy_id")
  message    String
  logType    String   @default("info")
  createdAt  DateTime @default(now()) @map("created_at")
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("strategy_logs")
}

model StrategyBacktest {
  id          String   @id @default(uuid())
  strategyId  String   @map("strategy_id")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  pnl         Decimal  @db.Decimal(12, 2)
  winRate     Decimal  @map("win_rate") @db.Decimal(5, 2)
  totalTrades Int      @map("total_trades")
  configJson  String?  @map("config_json")
  status      String   @default("completed")
  createdAt   DateTime @default(now()) @map("created_at")
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("strategy_backtests")
}
