// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  mobile    String?
  userId    String   @unique @map("user_id")
  password  String
  role      String   @default("client") // admin, client
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client       Client?
  subscriptions Subscription[]
  payments     Payment[]
  auditLogs    AuditLog[]
  tickets      SupportTicket[]

  @@map("users")
}

model Client {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  zerodhaClientId    String?   @map("zerodha_client_id")
  accessToken        String?   @map("access_token")
  capital            Decimal   @db.Decimal(12, 2)
  riskPercentage     Decimal   @default(1.00) @map("risk_percentage") @db.Decimal(5, 2)
  strategyId         String?   @map("strategy_id")
  strategy           Strategy? @relation(fields: [strategyId], references: [id])
  tradingStatus      String    @default("inactive") @map("trading_status") // active, inactive
  subscriptionStatus String    @default("pending") @map("subscription_status") // active, expired, pending
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  trades Trade[]

  @@map("clients")
}

model Strategy {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, inactive
  configJson  String?  @map("config_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  clients Client[]
  trades  Trade[]

  @@map("strategies")
}

model Trade {
  id         String    @id @default(uuid())
  clientId   String    @map("client_id")
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  strategyId String    @map("strategy_id")
  strategy   Strategy  @relation(fields: [strategyId], references: [id])
  symbol     String
  orderType  String    @map("order_type")
  entryPrice Decimal?  @map("entry_price") @db.Decimal(12, 2)
  exitPrice  Decimal?  @map("exit_price") @db.Decimal(12, 2)
  quantity   Int
  stopLoss   Decimal?  @map("stop_loss") @db.Decimal(12, 2)
  target     Decimal?  @db.Decimal(12, 2)
  pnl        Decimal?  @db.Decimal(12, 2)
  status     String    @default("open") // open, closed, cancelled, failed
  entryTime  DateTime? @map("entry_time")
  exitTime   DateTime? @map("exit_time")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("trades")
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  durationDays Int      @map("duration_days")
  features     String?  // JSON string
  status       String   @default("active") // active, inactive
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  payments     Payment[]

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String           @map("plan_id")
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  status    String           @default("active") // active, expired, pending
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Payment {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId             String           @map("plan_id")
  plan               SubscriptionPlan @relation(fields: [planId], references: [id])
  amount             Decimal          @db.Decimal(10, 2)
  razorpayOrderId    String           @map("razorpay_order_id")
  razorpayPaymentId  String?          @map("razorpay_payment_id")
  status             String
  paymentDate        DateTime?        @map("payment_date")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("payments")
}

model AppSettings {
  id           String   @id @default(uuid())
  settingKey   String   @unique @map("setting_key")
  settingValue String   @map("setting_value")
  type         String   @default("string") // string, json, boolean
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  admin     User     @relation(fields: [adminId], references: [id])
  action    String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  category  String
  status    String   @default("open") // open, in-progress, resolved
  reply     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("support_tickets")
}
